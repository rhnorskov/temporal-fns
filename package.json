{
	"name": "temporal-fns",
	"version": "2.0.0",
	"description": "A utility library for working with JavaScript Temporal objects, providing helper functions for date and time manipulations.",
	"keywords": [
		"temporal",
		"temporal-fns",
		"dates",
		"times",
		"javascript",
		"date-utilities",
		"typescript",
		"time-functions",
		"date-fns"
	],
	"homepage": "https://github.com/rhnorskov/temporal-fns#readme",
	"bugs": {
		"url": "https://github.com/rhnorskov/temporal-fns/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/rhnorskov/temporal-fns.git"
	},
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"check": "biome check",
		"check:fix": "biome check --write",
		"release": "changeset publish",
		"type-check": "tsc --noEmit",
		"test": "vitest",
		"docs": "typedoc"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@changesets/cli": "^2.31.0",
		"@types/node": "^25.0.0",
		"tsdown": "^0.22.0",
		"typedoc": "^0.28.19",
		"typescript": "^6.0.3",
		"vitest": "^4.1.6"
	}
}
